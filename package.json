{
  "name": "clusiv-data",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "test:flow-layout": "node --experimental-strip-types src/lib/components/flows/flowLayout.test.mjs",
    "test:flow-graph": "node --experimental-strip-types --experimental-specifier-resolution=node src/lib/utils/flowGraphUtils.test.mjs",
    "test:home-text": "node --experimental-strip-types --experimental-loader ./scripts/test-alias-loader.mjs src/lib/utils/homeText.test.mjs",
    "test:linked-notes": "node --experimental-strip-types --experimental-loader ./scripts/test-alias-loader.mjs src/lib/utils/linkedNotes.test.mjs",
    "test:quick-texts": "node --experimental-strip-types src/lib/utils/quickTexts.test.mjs",
    "test:flows": "pnpm run test:flow-layout && pnpm run test:flow-graph",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "lucide-svelte": "^0.542.0",
    "svelte": "^5.38.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tauri-apps/cli": "^2.8.4",
    "@tsconfig/svelte": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "svelte-check": "^4.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vite": "^6.3.6"
  }
}
